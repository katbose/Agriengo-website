---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT, SOCIAL } from '../lib/constants';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with the AGRIENGO™ Consumer Wellness Cell for bulk orders, farm consulting, and product support."
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-title reveal">Contact Us</h1>
      <p class="page-subtitle reveal">We're here to help you grow. Reach out to our Consumer Wellness Cell.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        
        <!-- Contact Info -->
        <div class="contact-info-wrap reveal">
          <h2 class="section-heading">Get in Touch</h2>
          <p class="mb-4">Whether you have questions about our products, need advice on application, or want to discuss bulk orders, our team is ready to assist you.</p>

          <div class="contact-details">
            <div class="detail-item">
              <div class="detail-icon">📞</div>
              <div class="detail-content">
                <h4>Phone</h4>
                <a href={`tel:${CONTACT.phone}`}>{CONTACT.phone}</a>
              </div>
            </div>
            
            <div class="detail-item">
              <div class="detail-icon">✉️</div>
              <div class="detail-content">
                <h4>Email</h4>
                <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
              </div>
            </div>

            <div class="detail-item">
              <div class="detail-icon">🏢</div>
              <div class="detail-content">
                <h4>Consumer Wellness Cell</h4>
                <p>The Agri Engineer Organic Farms<br/>India</p>
              </div>
            </div>
          </div>

          <h3 class="follow-heading">Follow Us</h3>
          <div class="social-pills">
            {SOCIAL.map(s => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-pill">
                {s.name}
              </a>
            ))}
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-wrap reveal" style="transition-delay: 0.1s">
          <form class="contact-form" onsubmit="event.preventDefault(); alert('Thanks for reaching out! We will get back to you shortly.');">
            <h3 class="form-title">Send us a Message</h3>
            
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" required placeholder="John Doe" />
            </div>

            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" required placeholder="john@example.com" />
            </div>

            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject">
                <option value="general">General Inquiry</option>
                <option value="bulk">Bulk Order</option>
                <option value="support">Product Support</option>
                <option value="feedback">Feedback</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required placeholder="How can we help you today?"></textarea>
            </div>

            <button type="submit" class="btn btn--green btn--full">Send Message</button>
          </form>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  background: linear-gradient(to bottom, var(--green-pale), var(--cream));
  padding-top: calc(var(--nav-height) + 4rem);
  padding-bottom: 4rem;
  text-align: center;
}

.page-title {
  color: var(--green-darkest);
  margin-bottom: 1rem;
}

.page-subtitle {
  max-width: 600px;
  margin-inline: auto;
  font-size: 1.125rem;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  max-width: 1100px;
  margin-inline: auto;
}

.mb-4 {
  margin-bottom: 2rem;
  color: var(--text-mid);
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.detail-icon {
  font-size: 1.5rem;
  background: var(--green-pale);
  padding: 0.75rem;
  border-radius: 50%;
  line-height: 1;
}

.detail-content h4 {
  font-family: var(--font-sans);
  font-size: 1rem;
  color: var(--green-dark);
  margin-bottom: 0.25rem;
}

.detail-content a, .detail-content p {
  color: var(--text-mid);
  font-size: 1.0625rem;
}

.detail-content a:hover {
  color: var(--gold-dark);
}

.follow-heading {
  font-size: 1.125rem;
  margin-bottom: 1rem;
  color: var(--green-dark);
}

.social-pills {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.social-pill {
  background: var(--white-warm);
  border: 1px solid var(--cream-dark);
  padding: 0.5rem 1rem;
  border-radius: 999px;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--green-primary);
  transition: all 0.2s ease;
}

.social-pill:hover {
  background: var(--green-primary);
  color: var(--white-warm);
  border-color: var(--green-primary);
}

/* Form Styles */
.contact-form-wrap {
  background: var(--white-warm);
  padding: 2.5rem;
  border-radius: 1rem;
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  border-top: 4px solid var(--gold);
}

.form-title {
  font-size: 1.5rem;
  color: var(--green-darkest);
  margin-bottom: 1.5rem;
}

.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--green-dark);
  margin-bottom: 0.5rem;
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid var(--cream-dark);
  border-radius: 0.5rem;
  font-family: var(--font-sans);
  font-size: 1rem;
  background: var(--cream);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--green-light);
  box-shadow: 0 0 0 3px rgba(82, 183, 136, 0.2);
}

.btn--full {
  width: 100%;
  justify-content: center;
}

@media (max-width: 900px) {
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}
</style>
