---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/global/Icon.astro';
import { CONTACT, SOCIAL } from '../lib/constants';
---

<BaseLayout 
  title="Contact Us" 
  description="Get in touch with AGRIENGO™ for product inquiries, wholesale orders, or gardening support."
>
  <section class="page-hero">
    <div class="container">
      <p class="section-label reveal">Support & Inquiries</p>
      <h1 class="hero-title reveal">How Can We<br/><span class="text-gold">Help You Grow?</span></h1>
      <p class="hero-sub reveal">Our agronomists and support team are ready to assist you with any questions about soil health or our products.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info reveal">
          <div class="info-group">
            <h2 class="info-title">Consumer Wellness Cell</h2>
            <p class="info-desc">For general inquiries, gardening tips, and order tracking support.</p>
            
            <ul class="contact-methods">
              <li>
                <div class="method-icon"><Icon name="external-link" width="20" height="20" /></div>
                <div class="method-details">
                  <span class="method-label">Email Us</span>
                  <a href={`mailto:${CONTACT.email}`} class="method-value">{CONTACT.email}</a>
                </div>
              </li>
              <li>
                <div class="method-icon"><Icon name="arrow-right" width="20" height="20" /></div>
                <div class="method-details">
                  <span class="method-label">Call / WhatsApp</span>
                  <a href={`tel:${CONTACT.phone}`} class="method-value">{CONTACT.phone}</a>
                </div>
              </li>
            </ul>
          </div>

          <div class="info-group">
            <h2 class="info-title">Connect with Us</h2>
            <div class="social-grid">
              {SOCIAL.map(s => (
                <a href={s.url} target="_blank" rel="noopener" class="social-card" aria-label={`Follow on ${s.name}`}>
                  <Icon name={s.icon} width="24" height="24" />
                  <span>{s.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="contact-form-wrap reveal">
          <div class="form-card">
            <h2 class="form-title">Send a Message</h2>
            <form class="contact-form">
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Full Name</label>
                  <input type="text" id="name" placeholder="Pradeep Nagar" required />
                </div>
                <div class="form-group">
                  <label for="email">Email Address</label>
                  <input type="email" id="email" placeholder="name@example.com" required />
                </div>
              </div>
              
              <div class="form-group">
                <label for="subject">Subject</label>
                <select id="subject">
                  <option>General Inquiry</option>
                  <option>Wholesale / Bulk Orders</option>
                  <option>Gardening Support</option>
                  <option>Feedback / Suggestions</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message">Your Message</label>
                <textarea id="message" rows="5" placeholder="How can we help you?" required></textarea>
              </div>

              <button type="submit" class="btn btn--gold btn--lg btn--full">
                Send Message
                <Icon name="arrow-right" width="18" height="18" />
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container text-center reveal">
      <h2 class="section-heading">Frequently Asked Questions</h2>
      <p class="section-subheading">Maybe we've already answered your question? Check our user guides.</p>
      <div class="mt-8">
        <a href="/how-to-use#faq" class="btn btn--outline-dark">Browse FAQs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero {
  padding-block: 8rem 4rem;
  background: linear-gradient(135deg, var(--green-darkest) 0%, var(--green-dark) 100%);
  text-align: center;
}

.hero-title {
  font-size: clamp(2.5rem, 6vw, 4rem);
  color: var(--white-warm);
  line-height: 1.1;
  margin-block: 1rem 1.5rem;
}

.text-gold { color: var(--gold); }

.hero-sub {
  font-size: 1.25rem;
  color: rgba(255,255,255,0.7);
  max-width: 600px;
  margin-inline: auto;
}

.contact-grid {
  display: grid;
  grid-template-columns: 0.8fr 1.2fr;
  gap: 5rem;
  align-items: flex-start;
}

.info-group { margin-bottom: 4rem; }
.info-title { font-size: 1.5rem; color: var(--green-dark); margin-bottom: 1rem; }
.info-desc { font-size: 0.9375rem; color: var(--text-mid); margin-bottom: 2rem; }

.contact-methods { list-style: none; display: flex; flex-direction: column; gap: 2rem; }
.contact-methods li { display: flex; align-items: center; gap: 1.5rem; }

.method-icon {
  width: 48px;
  height: 48px;
  background: var(--green-pale);
  color: var(--green-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.method-details { display: flex; flex-direction: column; }
.method-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--text-light); margin-bottom: 0.25rem; }
.method-value { font-size: 1.125rem; font-weight: 700; color: var(--green-dark); text-decoration: none; transition: color 0.2s; }
.method-value:hover { color: var(--green-primary); }

.social-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.social-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  padding: 1.5rem;
  background: var(--cream);
  border-radius: 1rem;
  text-decoration: none;
  color: var(--green-dark);
  font-weight: 700;
  font-size: 0.8125rem;
  transition: all 0.3s ease;
}

.social-card:hover { transform: translateY(-5px); background: var(--green-pale); color: var(--green-primary); }

/* Form */
.form-card {
  background: var(--white-warm);
  border-radius: 2rem;
  padding: 3.5rem;
  box-shadow: 0 20px 60px rgba(0,0,0,0.08);
  border: 1px solid var(--cream-dark);
}

.form-title { font-size: 2rem; color: var(--green-dark); margin-bottom: 2.5rem; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.form-group { margin-bottom: 1.5rem; }

.form-group label {
  display: block;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--green-dark);
  margin-bottom: 0.5rem;
}

.form-group input, .form-group select, .form-group textarea {
  width: 100%;
  padding: 1rem;
  border-radius: 0.75rem;
  border: 1px solid var(--cream-dark);
  font-family: inherit;
  font-size: 1rem;
  outline: none;
  transition: border-color 0.2s;
}

.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  border-color: var(--green-primary);
}

.btn--full { width: 100%; justify-content: center; }

.mt-8 { margin-top: 2rem; }

@media (max-width: 1000px) {
  .contact-grid { grid-template-columns: 1fr; gap: 4rem; }
}

@media (max-width: 600px) {
  .form-row { grid-template-columns: 1fr; }
  .form-card { padding: 2rem; }
  .social-grid { grid-template-columns: 1fr; }
}
</style>
