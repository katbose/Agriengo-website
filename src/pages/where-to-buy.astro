---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/global/Icon.astro';
import { MARKETPLACES } from '../lib/constants';

const ecommerce = MARKETPLACES.filter(m => m.type === 'ecommerce');
const quickCommerce = MARKETPLACES.filter(m => m.type === 'quick');
---

<BaseLayout 
  title="Where to Buy" 
  description="Order AGRIENGO™ Premium Vermi Compost from India's leading marketplaces including Amazon, Flipkart, Blinkit, and more."
>
  <section class="page-hero">
    <div class="container">
      <p class="section-label reveal">Marketplace Hub</p>
      <h1 class="hero-title reveal">Get It Delivered<br/><span class="text-gold">To Your Door</span></h1>
      <p class="hero-sub reveal">AGRIENGO™ is available across all major e-commerce and quick-commerce platforms for your convenience.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="market-section">
        <h2 class="section-heading reveal">E-Commerce Platforms</h2>
        <p class="section-subheading reveal">Best for bulk orders (5KG) and scheduled deliveries across India.</p>
        
        <div class="market-grid">
          {ecommerce.map(m => (
            <div class="market-card reveal">
              <div class="market-card__icon">
                <Icon name={m.icon} width="32" height="32" />
              </div>
              <div class="market-card__content">
                <h3>{m.name}</h3>
                <p>{m.description}</p>
                <a href={m.url} target="_blank" rel="noopener" class="btn btn--gold btn--sm">Shop on {m.name}</a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="market-section">
        <h2 class="section-heading reveal">Quick-Commerce (10-Min Delivery)</h2>
        <p class="section-subheading reveal">Perfect for when you need to repot that plant right now. Available in select cities.</p>
        
        <div class="market-grid">
          {quickCommerce.map(m => (
            <div class="market-card reveal">
              <div class="market-card__icon text-lightning">
                <Icon name={m.icon} width="32" height="32" />
              </div>
              <div class="market-card__content">
                <h3>{m.name}</h3>
                <p>{m.description}</p>
                <a href={m.url} target="_blank" rel="noopener" class="btn btn--green btn--sm">Order on {m.name}</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--green">
    <div class="container text-center reveal">
      <h2 class="section-heading section-heading--light">Wholesale & Bulk Inquiries</h2>
      <p class="section-subheading section-heading--light">Are you a nursery, landscaper, or organic farm? Contact us directly for institutional pricing.</p>
      <div class="mt-8">
        <a href="/contact" class="btn btn--gold btn--lg">Contact Sales Team</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero {
  padding-block: 8rem 4rem;
  background: linear-gradient(135deg, var(--green-darkest) 0%, var(--green-dark) 100%);
  text-align: center;
}

.hero-title {
  font-size: clamp(2.5rem, 6vw, 4rem);
  color: var(--white-warm);
  line-height: 1.1;
  margin-block: 1rem 1.5rem;
}

.text-gold { color: var(--gold); }

.hero-sub {
  font-size: 1.25rem;
  color: rgba(255,255,255,0.7);
  max-width: 600px;
  margin-inline: auto;
}

.market-section { margin-bottom: 5rem; }

.market-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 2rem;
  margin-top: 3rem;
}

.market-card {
  background: var(--white-warm);
  border: 1px solid var(--cream-dark);
  border-radius: 1.5rem;
  padding: 2.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all 0.3s var(--ease-out);
}

.market-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 15px 35px rgba(0,0,0,0.06);
  border-color: var(--green-light);
}

.market-card__icon {
  width: 64px;
  height: 64px;
  background: var(--cream);
  color: var(--green-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
}

.text-lightning { color: #FFA500; background: #FFF8E1; }

.market-card h3 { font-size: 1.5rem; color: var(--green-dark); margin-bottom: 0.5rem; }
.market-card p { font-size: 0.9375rem; color: var(--text-mid); margin-bottom: 2rem; }

.market-card .btn { width: 100%; justify-content: center; }

.mt-8 { margin-top: 2rem; }

@media (max-width: 600px) {
  .market-grid { grid-template-columns: 1fr; }
}
</style>
