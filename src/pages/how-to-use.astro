---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    q: "How often should I use vermicompost?",
    a: "For potted plants, apply every 3-4 weeks. For garden beds, apply at the beginning of the planting season and then once every 2 months."
  },
  {
    q: "Can I use too much vermicompost?",
    a: "Unlike chemical fertilizers, vermicompost is natural and will not burn your plants. However, a layer of 1-2 inches is usually sufficient for optimal results."
  },
  {
    q: "Does it smell bad?",
    a: "No! High-quality vermicompost like AGRIENGO has an earthy, natural smell similar to a forest floor after rain."
  },
  {
    q: "Can I mix it with other fertilizers?",
    a: "Yes, but it's often not necessary. Vermicompost provides a balanced mix of nutrients. If using other organic fertilizers, you can mix them to create a custom blend."
  }
];
---

<BaseLayout
  title="How to Use"
  description="Learn how to properly apply AGRIENGO™ Premium Vermi Compost for potted plants, garden beds, and agriculture."
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-title reveal">How to Use AGRIENGO™</h1>
      <p class="page-subtitle reveal">A simple guide to unlocking the full potential of your organic vermicompost.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      
      <!-- Application Guide -->
      <div class="guide-grid">
        <div class="guide-card reveal">
          <div class="guide-icon">🪴</div>
          <h3 class="guide-title">Potted Plants (Indoor & Outdoor)</h3>
          <ul class="guide-steps">
            <li><strong>New Potting:</strong> Mix 1 part AGRIENGO with 3 parts potting soil.</li>
            <li><strong>Existing Plants:</strong> Loosen the top 1 inch of soil. Add a handful of vermicompost around the base of the plant.</li>
            <li><strong>Watering:</strong> Water lightly immediately after application.</li>
            <li><strong>Frequency:</strong> Repeat every 3-4 weeks.</li>
          </ul>
        </div>

        <div class="guide-card reveal" style="transition-delay: 0.1s">
          <div class="guide-icon">🏡</div>
          <h3 class="guide-title">Home Gardens & Flower Beds</h3>
          <ul class="guide-steps">
            <li><strong>Preparation:</strong> Spread a 1-2 inch layer over the soil surface.</li>
            <li><strong>Mixing:</strong> Gently mix it into the top 2-3 inches of the soil using a trowel.</li>
            <li><strong>Watering:</strong> Water thoroughly to help nutrients reach the roots.</li>
            <li><strong>Frequency:</strong> Apply at planting and then once every 2 months.</li>
          </ul>
        </div>

        <div class="guide-card reveal" style="transition-delay: 0.2s">
          <div class="guide-icon">🌳</div>
          <h3 class="guide-title">Trees & Shrubs</h3>
          <ul class="guide-steps">
            <li><strong>Application:</strong> Dig a shallow trench around the drip line of the tree.</li>
            <li><strong>Amount:</strong> Apply 1-2 kg per tree depending on its size.</li>
            <li><strong>Covering:</strong> Cover the vermicompost with a layer of soil or mulch.</li>
            <li><strong>Frequency:</strong> Apply twice a year, ideally in spring and autumn.</li>
          </ul>
        </div>
      </div>

      <div class="divider reveal" style="margin-block: 4rem auto;"></div>

      <!-- FAQ Section -->
      <div class="faq-section reveal" id="faq">
        <h2 class="section-heading text-center">Frequently Asked Questions</h2>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <h4 class="faq-question">{faq.q}</h4>
              <p class="faq-answer">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  background: linear-gradient(to bottom, var(--green-pale), var(--cream));
  padding-top: calc(var(--nav-height) + 4rem);
  padding-bottom: 4rem;
  text-align: center;
}

.page-title {
  color: var(--green-darkest);
  margin-bottom: 1rem;
}

.page-subtitle {
  max-width: 600px;
  margin-inline: auto;
  font-size: 1.125rem;
}

.guide-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
  max-width: 1100px;
  margin-inline: auto;
}

.guide-card {
  background: var(--white-warm);
  padding: 2.5rem;
  border-radius: 1rem;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  border-top: 4px solid var(--green-primary);
}

.guide-icon {
  font-size: 3rem;
  margin-bottom: 1.5rem;
}

.guide-title {
  font-size: 1.25rem;
  color: var(--green-dark);
  margin-bottom: 1.5rem;
}

.guide-steps {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.guide-steps li {
  font-size: 0.9375rem;
  color: var(--text-mid);
  line-height: 1.5;
  padding-left: 1.5rem;
  position: relative;
}

.guide-steps li::before {
  content: "•";
  color: var(--gold);
  position: absolute;
  left: 0;
  font-size: 1.5rem;
  line-height: 1;
  top: -2px;
}

.guide-steps strong {
  color: var(--text-dark);
}

.text-center {
  text-align: center;
}

.faq-section {
  max-width: 800px;
  margin-inline: auto;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-top: 2.5rem;
}

.faq-item {
  background: var(--white-warm);
  padding: 1.5rem;
  border-radius: 0.75rem;
  border-left: 3px solid var(--gold);
}

.faq-question {
  font-family: var(--font-sans);
  font-size: 1.125rem;
  color: var(--green-dark);
  margin-bottom: 0.5rem;
}

.faq-answer {
  font-size: 0.9375rem;
  color: var(--text-mid);
}
</style>
