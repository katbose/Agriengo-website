---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRODUCTS, TRUST_BADGES, MARKETPLACES } from '../lib/constants';
import Icon from '../components/global/Icon.astro';
---

<BaseLayout
  title="Home"
  description="AGRIENGO™ Premium Vermi Compost — Grade-A NPK Enriched. Lab tested, 100% organic fertiliser. Shop on Amazon, Flipkart, Blinkit & more."
>
  <!-- ===================== HERO ===================== -->
  <section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-content container">
      <div class="hero-text">
        <span class="hero-eyebrow">
          <Icon name="leaf" width="14" height="14" class="inline-block mr-1" />
          100% Organic · Lab Tested · Grade-A NPK
        </span>
        <h1 class="hero-headline">
          Feed Your Soil.<br />
          <span class="hero-headline--gold">Feed the Planet.</span>
        </h1>
        <p class="hero-sub">
          AGRIENGO™ Premium Vermi Compost is engineered by Agri-Engineer and trusted by thousands of gardeners across India. Richer soil. Healthier roots. Better harvests.
        </p>
        <div class="hero-actions">
          <a href="/where-to-buy" class="btn btn--gold btn--lg" id="hero-shop-cta" data-track="hero-buy-click">
            Shop Now
            <Icon name="arrow-right" width="18" height="18" />
          </a>
          <a href="/how-to-use" class="btn btn--outline btn--lg" id="hero-learn-cta" data-track="hero-learn-click">Learn How to Use</a>
        </div>
        <div class="hero-badges">
          {TRUST_BADGES.map(b => (
            <span class="hero-badge">
              <Icon name={b.icon} width="16" height="16" />
              {b.label}
            </span>
          ))}
        </div>
      </div>
      <div class="hero-image-wrap">
        <div class="hero-glow"></div>
        <img
          src="/images/products/adriengo_vermiCompost_1kg.png"
          alt="AGRIENGO Premium Vermi Compost 1 KG Pack"
          class="hero-product-img"
          width="480"
          height="520"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
    <div class="hero-wave">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="var(--cream)"/></svg>
    </div>
  </section>

  <!-- ===================== TRUST BAR ===================== -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-stat"><span class="trust-num">3+</span><span class="trust-label">SKUs Available</span></div>
      <div class="trust-divider"></div>
      <div class="trust-stat"><span class="trust-num">6</span><span class="trust-label">Platforms to Buy</span></div>
      <div class="trust-divider"></div>
      <div class="trust-stat"><span class="trust-num">100%</span><span class="trust-label">Organic Certified</span></div>
      <div class="trust-divider"></div>
      <div class="trust-stat"><span class="trust-num">Grade-A</span><span class="trust-label">NPK Enriched</span></div>
    </div>
  </section>

  <!-- ===================== PRODUCTS ===================== -->
  <section class="section" id="products-preview">
    <div class="container">
      <p class="section-label reveal">Our Products</p>
      <h2 class="section-heading reveal">Choose Your Pack</h2>
      <p class="section-subheading reveal">Premium vermicompost in three convenient sizes — from starter kits to bulk value packs.</p>

      <div class="products-grid">
        {PRODUCTS.map((p, i) => (
          <div class={`product-card reveal ${p.tag === 'Most Popular' ? 'product-card--featured' : ''}`} style={`transition-delay: ${i * 0.1}s`}>
            {p.tag === 'Most Popular' && <div class="product-popular-bar">⭐ Most Popular</div>}
            <div class="product-img-wrap">
              <img
                src="/images/products/adriengo_vermiCompost_1kg.png"
                alt={`${p.name} — ${p.weight}`}
                class="product-img"
                width="240"
                height="260"
                loading="lazy"
              />
              <span class="product-tag-badge">
                <Icon name={p.tagIcon} width="14" height="14" />
                {p.tag}
              </span>
            </div>
            <div class="product-body">
              <h3 class="product-name">AGRIENGO™ Premium<br/>Vermi Compost</h3>
              <div class="product-weight">{p.weight}</div>
              <p class="product-desc">{p.description}</p>
              <ul class="product-benefits">
                {p.benefits.slice(0,3).map(b => (
                  <li>
                    <Icon name="check" width="14" height="14" class="benefit-dot" />
                    {b}
                  </li>
                ))}
              </ul>
              <a href="/where-to-buy" class={`btn ${p.tag === 'Most Popular' ? 'btn--gold' : 'btn--green'} btn--sm product-buy-btn`}>
                Buy Now →
              </a>
            </div>
          </div>
        ))}
      </div>
      <div class="products-cta-wrap">
        <a href="/products" class="btn btn--outline-dark">View All Products →</a>
      </div>
    </div>
  </section>

  <!-- ===================== WHY ORGANIC ===================== -->
  <section class="section section--green" id="why-organic">
    <div class="container">
      <p class="section-label section-label--light reveal">Why Choose AGRIENGO™</p>
      <h2 class="section-heading section-heading--light reveal">Science-Backed. Nature-Made.</h2>
      <div class="benefits-grid">
        {[
          { icon: 'seedling', title: 'Enriches Soil Structure', desc: 'Improves aeration, drainage and water retention for healthier root zones.' },
          { icon: 'leaf', title: 'Promotes Seed Germination', desc: 'Enzyme-rich castings accelerate sprouting and early plant development.' },
          { icon: 'beaker', title: 'Boosts Microbial Activity', desc: 'Introduces billions of beneficial microorganisms into your soil ecosystem.' },
          { icon: 'shield', title: 'Lab Tested Quality', desc: 'Every batch is scientifically tested and certified Grade-A NPK enriched.' },
          { icon: 'microscope', title: 'Enhances Root Health', desc: 'Humic acids and growth hormones encourage deep, strong root systems.' },
          { icon: 'leaf', title: 'Rich in Nutrients', desc: 'Natural nitrogen, phosphorus, potassium and 50+ micro-nutrients.' },
        ].map((item, i) => (
          <div class="benefit-card reveal" style={`transition-delay: ${i * 0.08}s`}>
            <div class="benefit-icon">
              <Icon name={item.icon} width="32" height="32" />
            </div>
            <h4 class="benefit-title">{item.title}</h4>
            <p class="benefit-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== LAB RESULTS (NPK) ===================== -->
  <section class="section" id="lab-results">
    <div class="container">
      <div class="lab-grid">
        <div class="lab-content reveal">
          <p class="section-label">Grade-A Quality</p>
          <h2 class="section-heading">Scientifically Analyzed. Lab Certified.</h2>
          <p class="section-subheading">Every batch of AGRIENGO™ vermicompost undergoes rigorous testing to ensure maximum nutrient density and zero pathogens.</p>
          
          <ul class="lab-stats">
            <li>
              <span class="stat-value">25-30%</span>
              <span class="stat-label">Moisture Content</span>
            </li>
            <li>
              <span class="stat-value">1.5 - 2.5%</span>
              <span class="stat-label">Total Nitrogen (N)</span>
            </li>
            <li>
              <span class="stat-value">1.0 - 1.5%</span>
              <span class="stat-label">Phosphorus (P)</span>
            </li>
            <li>
              <span class="stat-value">1.5 - 2.0%</span>
              <span class="stat-label">Potassium (K)</span>
            </li>
          </ul>
          
          <div class="lab-cta">
            <a href="/how-to-use#lab-report" class="btn btn--outline-dark">
              View Full Lab Report
              <Icon name="external-link" width="16" height="16" />
            </a>
          </div>
        </div>
        
        <div class="lab-visual reveal">
          <div class="npk-chart">
            <div class="npk-circle">
              <span class="npk-title">Grade-A</span>
              <span class="npk-subtitle">Enriched</span>
            </div>
            <div class="npk-label npk-label--n"><span>N</span>Nitrogen</div>
            <div class="npk-label npk-label--p"><span>P</span>Phosphorus</div>
            <div class="npk-label npk-label--k"><span>K</span>Potassium</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== AVAILABLE ON ===================== -->
  <section class="marketplace-bar" id="marketplaces">
    <div class="container">
      <p class="marketplace-label">Available on Your Favorite Platforms</p>
      <div class="marketplace-grid">
        {MARKETPLACES.map(m => (
          <a href={m.url} target="_blank" rel="noopener" class="marketplace-link" aria-label={`Shop on ${m.name}`}>
            <span class="marketplace-icon">
              <Icon name={m.icon} width="20" height="20" />
            </span>
            <span class="marketplace-name">{m.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-banner" id="cta-banner">
    <div class="container cta-banner__inner">
      <div class="cta-text">
        <h2 class="cta-heading">Ready to Transform Your Garden?</h2>
        <p class="cta-sub">Available on Amazon, Flipkart, Blinkit, Zepto, BigBasket & Swiggy Instamart.</p>
      </div>
      <a href="/where-to-buy" class="btn btn--gold btn--lg" id="home-bottom-cta">
        Where to Buy →
      </a>
    </div>
  </section>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Hero Animations
    const initHero = () => {
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      
      tl.from('.hero-eyebrow', { opacity: 0, y: 15, duration: 0.5 })
        .from('.hero-headline', { opacity: 0, y: 20, duration: 0.7 }, '-=0.2')
        .from('.hero-sub', { opacity: 0, y: 15, duration: 0.5 }, '-=0.4')
        .from('.hero-actions .btn', { 
          opacity: 0, 
          y: 15, 
          stagger: 0.1, 
          duration: 0.5, 
          clearProps: "all" 
        }, '-=0.2')
        .from('.hero-badge', { opacity: 0, x: -10, stagger: 0.05, duration: 0.4 }, '-=0.2')
        .from('.hero-image-wrap', { opacity: 0, x: 30, duration: 0.8 }, '-=0.6');
    };

    if (document.readyState === 'complete') {
      initHero();
    } else {
      window.addEventListener('load', initHero);
    }

    // Staggered reveals for benefit cards
    gsap.from('.benefit-card', {
      scrollTrigger: {
        trigger: '.benefits-grid',
        start: 'top 80%',
      },
      opacity: 0,
      y: 40,
      stagger: 0.1,
      duration: 0.8,
      ease: 'power3.out'
    });
    
    // NPK Stats animation
    gsap.from('.lab-stats li', {
      scrollTrigger: {
        trigger: '.lab-stats',
        start: 'top 85%',
      },
      opacity: 0,
      scale: 0.9,
      stagger: 0.15,
      duration: 0.8,
      ease: 'back.out(1.2)'
    });
  </script>
</BaseLayout>

<style>
/* ===== HERO ===== */
#hero {
  background: linear-gradient(135deg, var(--green-darkest) 0%, var(--green-dark) 50%, var(--green-primary) 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding-top: var(--nav-height);
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 70% 50%, rgba(82,183,136,0.12) 0%, transparent 65%),
              radial-gradient(ellipse at 20% 80%, rgba(212,168,67,0.08) 0%, transparent 50%);
  pointer-events: none;
}

.hero-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 3rem;
  padding-block: 4rem;
  position: relative;
  z-index: 1;
}

.hero-eyebrow {
  display: inline-block;
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--green-light);
  margin-bottom: 1rem;
  text-transform: uppercase;
}

.hero-headline {
  color: var(--white-warm);
  margin-bottom: 1.25rem;
  line-height: 1.15;
}

.hero-headline--gold { color: var(--gold); }

.hero-sub {
  font-size: 1.0625rem;
  color: rgba(255,255,255,0.75);
  max-width: 500px;
  margin-bottom: 2rem;
  line-height: 1.75;
}

.hero-actions {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
  position: relative;
  z-index: 10;
}

.hero-badges {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.35rem 0.85rem;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  letter-spacing: 0.04em;
}

.hero-image-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-glow {
  position: absolute;
  width: 770px;
  height: 770px;
  background: radial-gradient(circle, rgba(212,168,67,0.18) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-product-img {
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 24px 48px rgba(0,0,0,0.4));
  animation: float 6s ease-in-out infinite;
  max-width: 830px;
  width: 100%;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16px); }
}

.hero-wave {
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 80px;
}

.hero-wave svg { width: 100%; height: 100%; }

/* ===== TRUST BAR ===== */
.trust-bar {
  background: var(--white-warm);
  border-bottom: 1px solid var(--cream-dark);
  padding-block: 2rem;
}

.trust-bar__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
}

.trust-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
}

.trust-num {
  font-family: var(--font-serif);
  font-size: 1.625rem;
  font-weight: 700;
  color: var(--green-dark);
  line-height: 1;
}

.trust-label {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-light);
}

.trust-divider {
  width: 1px;
  height: 36px;
  background: var(--cream-dark);
}

/* ===== PRODUCTS GRID ===== */
.products-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}

.product-card {
  background: var(--white-warm);
  border-radius: 1.25rem;
  overflow: hidden;
  border: 2px solid transparent;
  box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out), border-color 0.3s ease;
  display: flex;
  flex-direction: column;
}

.product-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.12);
  border-color: var(--green-light);
}

.product-card--featured {
  border-color: var(--gold);
  box-shadow: 0 4px 32px rgba(212,168,67,0.15);
}

.product-card--featured:hover {
  border-color: var(--gold-dark);
  box-shadow: 0 16px 48px rgba(212,168,67,0.25);
}

.product-popular-bar {
  background: linear-gradient(90deg, var(--gold), var(--gold-dark));
  color: var(--green-darkest);
  text-align: center;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 0.35rem;
}

.product-img-wrap {
  position: relative;
  background: linear-gradient(135deg, var(--cream) 0%, var(--green-pale) 100%);
  padding: 2rem;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 200px;
}

.product-img {
  max-width: 160px;
  filter: drop-shadow(0 8px 24px rgba(0,0,0,0.15));
  transition: transform 0.3s var(--ease-out);
}

.product-card:hover .product-img { transform: scale(1.05); }

.product-tag-badge {
  position: absolute;
  top: 0.75rem;
  right: 0.75rem;
  padding: 0.25rem 0.6rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  background: var(--green-dark);
  color: var(--white-warm);
  letter-spacing: 0.04em;
}

.product-card--featured .product-tag-badge {
  background: var(--gold);
  color: var(--green-darkest);
}

.product-body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.product-name {
  font-size: 1rem;
  color: var(--green-dark);
  margin-bottom: 0.35rem;
}

.product-weight {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--green-primary);
  margin-bottom: 0.75rem;
}

.product-desc {
  font-size: 0.8125rem;
  line-height: 1.6;
  color: var(--text-mid);
  margin-bottom: 1rem;
}

.product-benefits {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  margin-bottom: 1.25rem;
  flex: 1;
}

.product-benefits li {
  font-size: 0.8125rem;
  color: var(--text-mid);
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.benefit-dot {
  color: var(--green-mid);
  font-weight: 700;
  flex-shrink: 0;
}

.product-buy-btn { width: 100%; justify-content: center; margin-top: auto; }

.products-cta-wrap { text-align: center; }

.btn--outline-dark {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.75rem;
  border-radius: 0.375rem;
  font-weight: 700;
  font-size: 0.9375rem;
  border: 2px solid var(--green-primary);
  color: var(--green-primary);
  transition: all 0.25s var(--ease-out);
  text-decoration: none;
}

.btn--outline-dark:hover {
  background: var(--green-primary);
  color: var(--white-warm);
  transform: translateY(-2px);
}

/* ===== WHY ORGANIC ===== */
.section--green {
  background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-primary) 100%);
}

.section-label--light { color: var(--gold-light); }
.section-heading--light { color: var(--white-warm); }

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.benefit-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 1rem;
  padding: 1.75rem;
  transition: background 0.3s ease, transform 0.3s ease;
}

.benefit-card:hover {
  background: rgba(255,255,255,0.1);
  transform: translateY(-4px);
}

.benefit-icon {
  font-size: 2rem;
  margin-bottom: 0.75rem;
  display: block;
}

.benefit-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--white-warm);
  margin-bottom: 0.5rem;
  font-family: var(--font-sans);
}

.benefit-desc {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.65;
}

/* ===== CTA BANNER ===== */
.cta-banner {
  background: linear-gradient(135deg, var(--gold-dark) 0%, var(--gold) 50%, var(--gold-light) 100%);
  padding-block: 4rem;
}

.cta-banner__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}

.cta-heading {
  font-size: clamp(1.5rem, 3vw, 2rem);
  color: var(--green-darkest);
  margin-bottom: 0.5rem;
}

.cta-sub {
  color: rgba(15,45,30,0.75);
  font-size: 1rem;
}

.cta-banner .btn--gold {
  background: var(--green-dark);
  border-color: var(--green-dark);
  color: var(--white-warm);
  flex-shrink: 0;
}

.cta-banner .btn--gold:hover {
  background: var(--green-darkest);
  border-color: var(--green-darkest);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}

/* ===== LAB RESULTS ===== */
.lab-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 4rem;
  align-items: center;
}

.lab-stats {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
  margin-block: 2.5rem;
}

.lab-stats li {
  display: flex;
  flex-direction: column;
  padding: 1.5rem;
  background: var(--cream);
  border-radius: 1rem;
  border: 1px solid var(--cream-dark);
}

.stat-value {
  font-family: var(--font-serif);
  font-size: 2rem;
  font-weight: 700;
  color: var(--green-dark);
}

.stat-label {
  font-size: 0.8125rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-light);
  margin-top: 0.25rem;
}

.npk-chart {
  position: relative;
  width: 320px;
  height: 320px;
  margin-inline: auto;
}

.npk-circle {
  position: absolute;
  inset: 15%;
  background: var(--green-dark);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--white-warm);
  box-shadow: 0 20px 40px rgba(27,67,50,0.3);
  z-index: 2;
}

.npk-title { font-weight: 700; font-size: 1.25rem; }
.npk-subtitle { font-size: 0.75rem; opacity: 0.8; text-transform: uppercase; letter-spacing: 0.1em; }

.npk-label {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-mid);
}

.npk-label span {
  width: 48px;
  height: 48px;
  background: var(--white-warm);
  border: 2px solid var(--green-light);
  border-radius: 50%;
