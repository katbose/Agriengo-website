---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRODUCTS } from '../lib/constants';

const productSchema = PRODUCTS.map(p => ({
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": p.name,
  "image": `https://www.agriengo.in/images/products/adriengo_vermiCompost_1kg.png`,
  "description": p.description,
  "brand": {
    "@type": "Brand",
    "name": "AGRIENGO™"
  },
  "offers": {
    "@type": "Offer",
    "url": `https://www.agriengo.in/where-to-buy`,
    "priceCurrency": "INR",
    "availability": "https://schema.org/InStock"
  }
}));
---

<BaseLayout
  title="Products"
  description="Explore AGRIENGO™ Premium Vermi Compost. Available in 1kg, 2kg, and 5kg packs. Lab-tested organic fertiliser."
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <div class="page-header">
    <div class="container">
      <h1 class="page-title reveal">Our Products</h1>
      <p class="section-subheading reveal">Premium Grade-A NPK enriched vermicompost for every type of gardener.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="products-list">
        {PRODUCTS.map((p, index) => (
          <div class={`product-row reveal ${index % 2 !== 0 ? 'product-row--reverse' : ''}`}>
            <div class="product-image-col">
              <div class="image-wrapper">
                {p.tag && <span class="tag-badge">{p.tagIcon} {p.tag}</span>}
                <img 
                  src="/images/products/adriengo_vermiCompost_1kg.png" 
                  alt={`${p.name} - ${p.weight}`} 
                  class="product-image"
                />
              </div>
            </div>
            <div class="product-info-col">
              <h2 class="product-title">{p.name}</h2>
              <div class="product-weight-large">{p.weight} Pack</div>
              <p class="product-description">{p.description}</p>
              
              <h4 class="benefits-title">Key Benefits:</h4>
              <ul class="benefits-list">
                {p.benefits.map(b => (
                  <li><span class="check">✓</span>{b}</li>
                ))}
              </ul>
              
              <div class="product-actions">
                <a href="/where-to-buy" class="btn btn--gold btn--lg">
                  Buy Now
                </a>
                <a href="/how-to-use" class="btn btn--outline-dark btn--lg">
                  How to Use
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  background: linear-gradient(to bottom, var(--green-pale), var(--cream));
  padding-top: calc(var(--nav-height) + 4rem);
  padding-bottom: 4rem;
  text-align: center;
}

.page-title {
  color: var(--green-darkest);
  margin-bottom: 1rem;
}


.products-list {
  display: flex;
  flex-direction: column;
  gap: 5rem;
  max-width: 1000px;
  margin-inline: auto;
}

.product-row {
  display: flex;
  align-items: center;
  gap: 4rem;
  background: var(--white-warm);
  padding: 3rem;
  border-radius: 1.5rem;
  box-shadow: 0 4px 24px rgba(0,0,0,0.04);
}

.product-row--reverse {
  flex-direction: row-reverse;
}

.product-image-col {
  flex: 1;
}

.image-wrapper {
  position: relative;
  background: var(--cream);
  padding: 3rem;
  border-radius: 1rem;
  display: flex;
  justify-content: center;
  align-items: center;
}

.product-image {
  max-width: 250px;
  width: 100%;
  filter: drop-shadow(0 12px 32px rgba(0,0,0,0.15));
  transition: transform 0.4s var(--ease-out);
}

.product-row:hover .product-image {
  transform: scale(1.05) translateY(-10px);
}

.tag-badge {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  background: var(--gold);
  color: var(--green-darkest);
  padding: 0.4rem 1rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.875rem;
  z-index: 2;
  box-shadow: 0 4px 12px rgba(212,168,67,0.3);
}

.product-info-col {
  flex: 1.2;
}

.product-title {
  font-family: var(--font-serif);
  font-size: 2rem;
  color: var(--green-dark);
  margin-bottom: 0.5rem;
  line-height: 1.2;
}

.product-weight-large {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--green-primary);
  margin-bottom: 1.5rem;
  font-family: var(--font-sans);
}

.product-description {
  font-size: 1.0625rem;
  color: var(--text-mid);
  margin-bottom: 2rem;
  line-height: 1.6;
}

.benefits-title {
  font-size: 1.125rem;
  color: var(--text-dark);
  margin-bottom: 1rem;
}

.benefits-list {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-bottom: 2.5rem;
}

.benefits-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  font-size: 0.9375rem;
  color: var(--text-mid);
}

.check {
  color: var(--green-primary);
  font-weight: bold;
}

.product-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.btn--outline-dark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 1rem 2.25rem;
  border-radius: 0.375rem;
  font-weight: 700;
  font-size: 1.0625rem;
  border: 2px solid var(--green-primary);
  color: var(--green-primary);
  transition: all 0.25s var(--ease-out);
  text-decoration: none;
}

.btn--outline-dark:hover {
  background: var(--green-primary);
  color: var(--white-warm);
}

@media (max-width: 900px) {
  .product-row, .product-row--reverse {
    flex-direction: column;
    padding: 2rem;
    gap: 2rem;
  }
  
  .image-wrapper {
    padding: 2rem;
  }
  
  .product-image {
    max-width: 200px;
  }
  
  .benefits-list {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 480px) {
  .product-actions {
    flex-direction: column;
  }
  .product-actions .btn {
    width: 100%;
    justify-content: center;
  }
}
</style>
