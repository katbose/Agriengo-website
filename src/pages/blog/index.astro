---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/global/Icon.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-IN', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};
---

<BaseLayout 
  title="Gardening Blog" 
  description="Expert gardening tips, soil science, and organic farming guides from AGRIENGO™ agronomists."
>
  <section class="blog-hero">
    <div class="container">
      <p class="section-label reveal">Our Journal</p>
      <h1 class="hero-title reveal">Grow Smarter with<br/><span class="text-gold">Expert Insights</span></h1>
      <p class="hero-sub reveal">Dive into the science of soil health and discover the best practices for a thriving organic garden.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => (
          <article class="blog-card reveal">
            <a href={`/blog/${post.id}`} class="blog-card__link">
              <div class="blog-card__image">
                <img src={post.data.heroImage || '/images/blog/placeholder.jpg'} alt={post.data.title} />
                <div class="blog-card__category">{post.data.tags[0]}</div>
              </div>
              <div class="blog-card__content">
                <div class="blog-card__meta">
                  <span class="blog-card__date">
                    <Icon name="clock" width="14" height="14" />
                    {formatDate(post.data.pubDate)}
                  </span>
                  <span class="blog-card__author">By {post.data.author}</span>
                </div>
                <h2 class="blog-card__title">{post.data.title}</h2>
                <p class="blog-card__excerpt">{post.data.description}</p>
                <span class="blog-card__read-more">
                  Read Article
                  <Icon name="arrow-right" width="16" height="16" />
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.blog-hero {
  padding-block: 8rem 4rem;
  background: linear-gradient(135deg, var(--green-darkest) 0%, var(--green-dark) 100%);
  text-align: center;
}

.hero-title {
  font-size: clamp(2.5rem, 6vw, 4rem);
  color: var(--white-warm);
  line-height: 1.1;
  margin-block: 1rem 1.5rem;
}

.text-gold { color: var(--gold); }

.hero-sub {
  font-size: 1.25rem;
  color: rgba(255,255,255,0.7);
  max-width: 600px;
  margin-inline: auto;
}

.blog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 2.5rem;
}

.blog-card {
  background: var(--white-warm);
  border-radius: 1.5rem;
  overflow: hidden;
  border: 1px solid var(--cream-dark);
  transition: all 0.3s var(--ease-out);
}

.blog-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  border-color: var(--green-light);
}

.blog-card__link { text-decoration: none; color: inherit; }

.blog-card__image {
  position: relative;
  aspect-ratio: 16 / 10;
  overflow: hidden;
}

.blog-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.blog-card:hover .blog-card__image img { transform: scale(1.05); }

.blog-card__category {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background: var(--green-dark);
  color: var(--white-warm);
  padding: 0.35rem 0.85rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.blog-card__content { padding: 1.75rem; }

.blog-card__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
  font-size: 0.8125rem;
  color: var(--text-light);
}

.blog-card__date { display: flex; align-items: center; gap: 0.4rem; }

.blog-card__title {
  font-size: 1.5rem;
  color: var(--green-dark);
  margin-bottom: 1rem;
  line-height: 1.3;
}

.blog-card__excerpt {
  font-size: 0.9375rem;
  color: var(--text-mid);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.blog-card__read-more {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 700;
  color: var(--green-primary);
  font-size: 0.9375rem;
}

@media (max-width: 600px) {
  .blog-grid { grid-template-columns: 1fr; }
  .blog-hero { padding-block: 6rem 3rem; }
}
</style>
