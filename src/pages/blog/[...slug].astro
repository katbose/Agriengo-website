---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
>
  <div class="blog-post-header">
    <div class="container max-w-content">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <div class="post-meta">
        <span class="post-date">
          {post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </span>
        <span class="post-author">By {post.data.author}</span>
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-tags">
        {post.data.tags.map(tag => (
          <span class="post-tag">{tag}</span>
        ))}
      </div>
    </div>
  </div>

  <article class="section post-content-section">
    <div class="container max-w-content">
      <div class="prose">
        <Content />
      </div>
      
      <div class="post-footer">
        <div class="post-cta">
          <h3>Ready to start growing organically?</h3>
          <p>Get the premium vermicompost mentioned in this article.</p>
          <a href="/where-to-buy" class="btn btn--gold">Shop Now</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
.max-w-content {
  max-width: 800px;
  margin-inline: auto;
}

.blog-post-header {
  background: linear-gradient(to bottom, var(--green-pale), var(--cream));
  padding-top: calc(var(--nav-height) + 4rem);
  padding-bottom: 3rem;
  text-align: center;
}

.back-link {
  display: inline-block;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--green-primary);
  margin-bottom: 2rem;
  text-decoration: none;
  transition: color 0.2s;
}

.back-link:hover {
  color: var(--gold-dark);
}

.post-meta {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  font-size: 0.875rem;
  color: var(--text-light);
  margin-bottom: 1.5rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 600;
}

.post-meta span:not(:last-child)::after {
  content: "•";
  margin-left: 1rem;
  color: var(--cream-dark);
}

.post-title {
  color: var(--green-darkest);
  font-size: clamp(2rem, 4vw, 3.5rem);
  margin-bottom: 2rem;
  line-height: 1.2;
}

.post-tags {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.post-tag {
  font-size: 0.8125rem;
  background: var(--white-warm);
  color: var(--green-dark);
  padding: 0.35rem 1rem;
  border-radius: 999px;
  font-weight: 600;
  border: 1px solid rgba(0,0,0,0.05);
}

.post-content-section {
  padding-top: 4rem;
  background: var(--white-warm);
}

/* Prose Styles (Markdown rendering) */
.prose {
  font-size: 1.125rem;
  line-height: 1.8;
  color: var(--text-dark);
}

.prose :global(h2) {
  font-family: var(--font-serif);
  font-size: 2rem;
  color: var(--green-dark);
  margin-top: 3rem;
  margin-bottom: 1.25rem;
}

.prose :global(h3) {
  font-family: var(--font-sans);
  font-size: 1.5rem;
  color: var(--green-darkest);
  margin-top: 2.5rem;
  margin-bottom: 1rem;
}

.prose :global(p) {
  margin-bottom: 1.5rem;
}

.prose :global(ul), .prose :global(ol) {
  margin-bottom: 1.5rem;
  padding-left: 1.5rem;
}

.prose :global(li) {
  margin-bottom: 0.5rem;
}

.prose :global(blockquote) {
  border-left: 4px solid var(--gold);
  background: var(--green-pale);
  padding: 1.5rem;
  margin-inline: 0;
  margin-bottom: 1.5rem;
  font-style: italic;
  border-radius: 0 0.5rem 0.5rem 0;
}

.prose :global(img) {
  width: 100%;
  height: auto;
  border-radius: 1rem;
  margin-block: 2.5rem;
}

.post-footer {
  margin-top: 4rem;
  padding-top: 3rem;
  border-top: 1px solid var(--cream-dark);
}

.post-cta {
  background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-primary) 100%);
  padding: 3rem;
  border-radius: 1rem;
  text-align: center;
  color: var(--white-warm);
}

.post-cta h3 {
  color: var(--gold);
  margin-bottom: 0.5rem;
  font-family: var(--font-sans);
  font-size: 1.5rem;
}

.post-cta p {
  margin-bottom: 2rem;
  font-size: 1.125rem;
  opacity: 0.9;
}
</style>
