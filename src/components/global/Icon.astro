// Default to leaf if not found
const svgPath = paths[name] || paths['leaf'];
const isFill = name === 'instagram' || name === 'facebook' || name === 'youtube';
---

<svg 
  class={className}
  width={width} 
  height={height} 
  viewBox="0 0 24 24" 
  fill={isFill ? "currentColor" : "none"}
  stroke={isFill ? "none" : "currentColor"}
  stroke-width={isFill ? "0" : "2"}
  set:html={svgPath}
/>
