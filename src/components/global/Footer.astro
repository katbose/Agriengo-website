---
import { BRAND, CONTACT, SOCIAL, FOOTER_LINKS, TRUST_BADGES } from '../../lib/constants';
import Icon from './Icon.astro';
---

<footer id="footer">
  <!-- Main Footer Grid -->
  <div class="footer-main">
    <div class="footer-container">

      <!-- Col 1: Brand -->
      <div class="footer-col footer-brand">
        <div class="footer-logo">
          <span class="footer-logo-text">AGRIENGO</span><sup class="footer-logo-tm">™</sup>
        </div>
        <p class="footer-logo-sub">{BRAND.fullName}</p>
        <p class="footer-tagline">"{BRAND.tagline}"</p>

        <!-- Trust Badges -->
        <div class="trust-badges">
          {TRUST_BADGES.map((badge) => (
            <span class="trust-badge">
              <span class="badge-icon">{badge.icon}</span>
              {badge.label}
            </span>
          ))}
        </div>

        <p class="footer-trademark">{BRAND.trademark}</p>
      </div>

      <!-- Col 2: Explore -->
      <div class="footer-col">
        <h3 class="footer-col-title">Explore</h3>
        <ul class="footer-links-list">
          {FOOTER_LINKS.explore.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Support & Legal -->
      <div class="footer-col">
        <h3 class="footer-col-title">Support</h3>
        <ul class="footer-links-list">
          {FOOTER_LINKS.support.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>

        <h3 class="footer-col-title footer-col-title--spaced">Legal</h3>
        <ul class="footer-links-list">
          {FOOTER_LINKS.legal.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Connect -->
      <div class="footer-col">
        <h3 class="footer-col-title">Connect With Us</h3>

        <!-- Social Icons -->
        <div class="social-links">
          {SOCIAL.map((s) => (
            <a
              href={s.url}
              class="social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${s.name} — ${s.handle}`}
            >
              <span class="social-icon">
                <Icon name={s.icon} width="18" height="18" />
              </span>
              <span>
                <span class="social-platform">{s.name}</span>
                <span class="social-handle">{s.handle}</span>
              </span>
            </a>
          ))}
        </div>

        <!-- Consumer Wellness Cell -->
        <div class="wellness-cell">
          <p class="wellness-title">Consumer Wellness Cell</p>
          <a href={`tel:${CONTACT.phone}`} class="wellness-item">
            <Icon name="check" width="16" height="16" /> {CONTACT.phone}
          </a>
          <a href={`mailto:${CONTACT.email}`} class="wellness-item">
            <Icon name="external-link" width="16" height="16" /> {CONTACT.email}
          </a>
          <a href={`https://${CONTACT.website}`} target="_blank" rel="noopener" class="wellness-item">
            <Icon name="globe" width="16" height="16" /> {CONTACT.website}
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="footer-container footer-bottom__inner">
      <p class="footer-copy">
        © 2026 <strong>AGRIENGO™</strong> — {BRAND.fullName}<br class="mobile-break" />
        <span class="footer-copy-sep"> All Rights Reserved</span>
        <span class="footer-copy-sep">|</span>
        <span class="footer-copy-sep">Trademark App. No. 7673426</span>
      </p>
      <p class="footer-made">Made with 🌱 in India</p>
    </div>
  </div>
</footer>

<style>
  #footer {
    background: var(--green-darkest);
    color: rgba(255,255,255,0.75);
    margin-top: auto;
  }

  /* ===== MAIN GRID ===== */
  .footer-main {
    padding-block: 4rem 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .footer-container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .footer-main .footer-container {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.2fr 1.3fr;
    gap: 3rem;
  }

  /* ===== COL 1: BRAND ===== */
  .footer-logo {
    display: flex;
    align-items: flex-start;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .footer-logo-text {
    font-family: var(--font-serif);
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--white-warm);
    letter-spacing: 0.04em;
  }

  .footer-logo-tm {
    font-size: 0.6rem;
    color: var(--gold);
    font-family: var(--font-sans);
    margin-top: 4px;
  }

  .footer-logo-sub {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--green-light);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .footer-tagline {
    font-size: 0.9375rem;
    font-style: italic;
    color: rgba(255,255,255,0.6);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  /* Trust Badges */
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.7rem;
    background: rgba(82, 183, 136, 0.12);
    border: 1px solid rgba(82, 183, 136, 0.25);
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--green-light);
  }

  .badge-icon { font-size: 0.875rem; }

  .footer-trademark {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.02em;
  }

  /* ===== COL TITLES ===== */
  .footer-col-title {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .footer-col-title--spaced {
    margin-top: 1.75rem;
  }

  /* ===== LINKS ===== */
  .footer-links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.2s ease, padding-left 0.2s ease;
    display: inline-block;
  }

  .footer-link:hover {
    color: var(--gold-light);
    padding-left: 4px;
  }

  /* ===== SOCIAL ===== */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: rgba(255,255,255,0.7);
    transition: color 0.2s ease, transform 0.2s ease;
    padding: 0.25rem 0;
  }

  .social-link:hover {
    color: var(--white-warm);
    transform: translateX(4px);
  }

  .social-icon {
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.08);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .social-link:hover .social-icon {
    background: rgba(212, 168, 67, 0.2);
    color: var(--gold);
  }

  .social-platform {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: rgba(255,255,255,0.85);
  }

  .social-handle {
    display: block;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.45);
  }

  /* ===== WELLNESS CELL ===== */
  .wellness-cell {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 1.25rem;
  }

  .wellness-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .wellness-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    margin-bottom: 0.4rem;
    transition: color 0.2s ease;
  }

  .wellness-item:hover { color: var(--white-warm); }

  /* ===== BOTTOM BAR ===== */
  .footer-bottom {
    padding-block: 1.25rem;
    background: rgba(0,0,0,0.2);
  }

  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
  }

  .footer-copy strong { color: rgba(255,255,255,0.7); }

  .footer-copy-sep {
    margin-inline: 0.35rem;
    opacity: 0.5;
  }

  .footer-made {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.45);
  }

  .mobile-break { display: none; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .footer-main .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 3rem;
    }
  }

  @media (max-width: 640px) {
    .footer-main .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-bottom__inner {
      flex-direction: column;
      text-align: center;
    }
    .footer-copy-sep { display: none; }
    .mobile-break { display: inline; }
    .footer-copy { text-align: center; }
  }
</style>
