---
import '../styles/global.css';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = 'AGRIENGO™ Premium Vermi Compost — Grade-A NPK Enriched organic fertiliser. Lab tested, 100% organic. Available on Amazon, Flipkart, Blinkit & more.',
  ogImage = '/images/og-default.jpg',
  canonical,
} = Astro.props;

const siteUrl = 'https://www.agriengo.in';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AGRIENGO™',
  alternateName: 'The Agri Engineer Organic Farms',
  url: siteUrl,
  logo: `${siteUrl}/images/logo/agriengo-logo.png`,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+91-7753827648',
    contactType: 'Customer Service',
    availableLanguage: ['English', 'Hindi'],
  },
  sameAs: [
    'https://instagram.com/agriengo',
    'https://facebook.com/agriengo',
    'https://youtube.com/@agriengo',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1B4332" />

    <!-- Primary Meta -->
    <title>{title} | AGRIENGO™</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | AGRIENGO™`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="AGRIENGO™" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | AGRIENGO™`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Scroll Reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
